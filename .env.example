# Copy to .env and fill in as needed. All values have sane local defaults.

# SQLAlchemy connection string for the relational store.
DATABASE_URL=sqlite:///./app.db

# LLM provider — see app/llm/client.py. Groq's API is OpenAI-schema-compatible,
# so llm_base_url can point at any compatible provider (OpenRouter, etc.)
LLM_PROVIDER=groq
LLM_API_KEY=your-api-key-here
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_TIMEOUT_SECONDS=30

LOG_LEVEL=INFO
